{
  "Protocol": "Yuan2024_GelMA_PRP_Microsphere_Protocol",
  "Stages": [
    {
      "order": 1,
      "stage_name": "PRP Preparation",
      "summary": "Isolate, activate, clarify, filter, and freeze PRP from anticoagulated human venous blood.",
      "depends_on": [],
      "evidence_refs": ["E01", "E02", "E03", "E04", "E05", "E06", "E07", "E08"]
    },
    {
      "order": 2,
      "stage_name": "GelMA Synthesis",
      "summary": "Synthesize GelMA from type A gelatin via methacrylation, purify by dialysis, and lyophilize.",
      "depends_on": [],
      "evidence_refs": ["E09", "E10", "E11", "E12"]
    },
    {
      "order": 3,
      "stage_name": "GelMA Precursor Preparation",
      "summary": "Dissolve lyophilized GelMA in PBS with photoinitiator and sterile-filter to obtain the precursor solution.",
      "depends_on": ["GelMA Synthesis"],
      "evidence_refs": ["E13", "E14"]
    },
    {
      "order": 4,
      "stage_name": "PRP-Loaded Microsphere Fabrication",
      "summary": "Generate GelMA-PRP microdroplets by microfluidics and UV-cure them into hydrogel microspheres, then wash and collect.",
      "depends_on": ["PRP Preparation", "GelMA Precursor Preparation"],
      "evidence_refs": ["E15", "E16", "E17", "E18", "E19"]
    },
    {
      "order": 5,
      "stage_name": "Composite Assembly",
      "summary": "Combine GelMA microspheres with PRP-containing hydrogel to form the final PRP@GelMA-M composite.",
      "depends_on": ["PRP-Loaded Microsphere Fabrication"],
      "evidence_refs": ["E20"]
    }
  ],

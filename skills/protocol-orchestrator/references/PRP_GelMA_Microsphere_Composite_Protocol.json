{

  "Protocol": "PRP_GelMA_Microsphere_Composite_Protocol",
  "Stages": [
    {
      "order": 1,
      "stage_name": "PRP Preparation",
      "summary": "Isolate, activate, clarify, filter, and freeze PRP from anticoagulated blood.",
      "depends_on": []
    },
    {
      "order": 2,
      "stage_name": "GelMA Synthesis",
      "summary": "Synthesize GelMA from gelatin, purify it, freeze it, and lyophilize it.",
      "depends_on": []
    },
    {
      "order": 3,
      "stage_name": "Precursor Preparation",
      "summary": "Prepare sterile GelMA precursor solution and combine it with PRP.",
      "depends_on": ["PRP Preparation", "GelMA Synthesis"]
    },
    {
      "order": 4,
      "stage_name": "Microsphere Fabrication",
      "summary": "Generate GelMA-PRP microdroplets by microfluidics and UV-cure them into microspheres.",
      "depends_on": ["Precursor Preparation"]
    },
    {
      "order": 5,
      "stage_name": "Post-processing and Composite Assembly",
      "summary": "Wash the microspheres and combine them with PRP-containing hydrogel to obtain the final composite.",
      "depends_on": ["Microsphere Fabrication"]
    }
  ],
  "Materials": [
    "Type A gelatin: 2 g",
    "PBS: about 110 mL total",
    "Methacrylic anhydride: 1.6 mL",
    "Photoinitiator: 0.5% w/v",
    "Human venous blood: 9 mL",
    "Sodium citrate anticoagulant: 1 mL",
    "CaCl2 solution: 10%",
    "Thrombin",
    "Paraffin oil",
    "Span 80: 5% v/v",
    "Double-distilled water"
  ],
  "Instruments": [
    "Centrifuge",
    "Magnetic stirrer",
    "Syringe pump",
    "Microfluidic device",
    "UV irradiation device",
    "Dialysis tubing",
    "Lyophilizer",
    "0.22 um filter",
    "-80 C freezer",
    "Incubator"
  ],
  "Containers": [
    "15 mL centrifuge tube",
    "Glass beaker",
    "Dialysis tube",
    "Syringe",
    "Collection vial",
    "Cryogenic storage vial"
  ],
  "Operations": [
    {
      "Type": "centrifugation",
      "Object": ["human venous blood", "sodium citrate anticoagulant"],
      "Container": "15 mL centrifuge tube",
      "Description": "Combine sodium citrate anticoagulant with venous blood and centrifuge to separate blood fractions.",
      "Instrument parameters": {
        "centrifuge": ["300 x g", "20 min", "room temperature"]
      },
      "Product": "stratified blood fractions",
      "belongto": "PRP Preparation"
    },
    {
      "Type": "transfer",
      "Object": ["stratified blood upper and junction layers"],
      "Container": "15 mL centrifuge tube",
      "Description": "Collect the platelet-rich upper and junction fractions.",
      "Instrument parameters": {},
      "Product": "collected platelet-rich fraction",
      "belongto": "PRP Preparation"
    },
    {
      "Type": "centrifugation",
      "Object": ["collected platelet-rich fraction"],
      "Container": "15 mL centrifuge tube",
      "Description": "Centrifuge the collected fraction again and recover PRP.",
      "Instrument parameters": {
        "centrifuge": ["300 x g", "20 min", "room temperature"]
      },
      "Product": "PRP",
      "belongto": "PRP Preparation"
    },
    {
      "Type": "mixing",
      "Object": ["PRP", "10% CaCl2", "thrombin"],
      "Container": "15 mL centrifuge tube",
      "Description": "Adjust platelet concentration and mix PRP with CaCl2 and thrombin to activate it.",
      "Instrument parameters": {},
      "Product": "activated PRP mixture",
      "belongto": "PRP Preparation"
    },
    {
      "Type": "incubation",
      "Object": ["activated PRP mixture"],
      "Container": "15 mL centrifuge tube",
      "Description": "Incubate the activated PRP mixture.",
      "Instrument parameters": {
        "incubator": ["37 C", "4 h"]
      },
      "Product": "incubated PRP",
      "belongto": "PRP Preparation"
    },
    {
      "Type": "centrifugation",
      "Object": ["incubated PRP"],
      "Container": "15 mL centrifuge tube",
      "Description": "Centrifuge the incubated PRP and collect the clarified supernatant.",
      "Instrument parameters": {
        "centrifuge": ["2000 x g", "10 min", "room temperature"]
      },
      "Product": "clarified PRP supernatant",
      "belongto": "PRP Preparation"
    },
    {
      "Type": "filtration",
      "Object": ["clarified PRP supernatant"],
      "Container": "15 mL centrifuge tube",
      "Description": "Filter the clarified PRP supernatant through a 0.22 um filter.",
      "Instrument parameters": {
        "filter": ["0.22 um pore size"]
      },
      "Product": "sterile filtered PRP",
      "belongto": "PRP Preparation"
    },
    {
      "Type": "cooling",
      "Object": ["sterile filtered PRP"],
      "Container": "cryogenic storage vial",
      "Description": "Freeze the sterile filtered PRP for later use.",
      "Instrument parameters": {
        "freezer": ["-80 C"]
      },
      "Product": "frozen PRP",
      "belongto": "PRP Preparation"
    },
    {
      "Type": "dissolution",
      "Object": ["type A gelatin: 2 g", "PBS: 20 mL"],
      "Container": "glass beaker",
      "Description": "Dissolve type A gelatin in PBS with heating and stirring.",
      "Instrument parameters": {
        "magnetic_stirrer": ["60 C", "stirring"]
      },
      "Product": "gelatin solution",
      "belongto": "GelMA Synthesis"
    },
    {
      "Type": "synthesis",
      "Object": ["gelatin solution", "methacrylic anhydride: 1.6 mL"],
      "Container": "glass beaker",
      "Description": "Add methacrylic anhydride dropwise to synthesize GelMA.",
      "Instrument parameters": {
        "syringe_pump": ["1.0 mL h-1"],
        "magnetic_stirrer": ["60 C", "3 h", "vigorous stirring"]
      },
      "Product": "crude GelMA solution",
      "belongto": "GelMA Synthesis"
    },
    {
      "Type": "mixing",
      "Object": ["crude GelMA solution", "PBS: 80 mL"],
      "Container": "glass beaker",
      "Description": "Dilute the crude GelMA solution with prewarmed PBS.",
      "Instrument parameters": {},
      "Product": "diluted GelMA mixture",
      "belongto": "GelMA Synthesis"
    },
    {
      "Type": "dialysis",
      "Object": ["diluted GelMA mixture"],
      "Container": "dialysis tube",
      "Description": "Dialyze the diluted GelMA mixture against water to remove unreacted components.",
      "Instrument parameters": {
        "dialysis_tubing": ["12-14 kDa MWCO", "7 days"]
      },
      "Product": "purified GelMA solution",
      "belongto": "GelMA Synthesis"
    },
    {
      "Type": "filtration",
      "Object": ["purified GelMA solution"],
      "Container": "glass beaker",
      "Description": "Filter the purified GelMA solution.",
      "Instrument parameters": {
        "filter": ["0.22 um pore size"]
      },
      "Product": "filtered GelMA solution",
      "belongto": "GelMA Synthesis"
    },
    {
      "Type": "cooling",
      "Object": ["filtered GelMA solution"],
      "Container": "glass beaker",
      "Description": "Freeze the filtered GelMA solution.",
      "Instrument parameters": {
        "freezer": ["-80 C", "overnight"]
      },
      "Product": "frozen GelMA",
      "belongto": "GelMA Synthesis"
    },
    {
      "Type": "lyophilization",
      "Object": ["frozen GelMA"],
      "Container": "glass beaker",
      "Description": "Lyophilize the frozen GelMA to obtain purified solid GelMA.",
      "Instrument parameters": {
        "lyophilizer": ["until dry"]
      },
      "Product": "lyophilized GelMA",
      "belongto": "GelMA Synthesis"
    },
    {
      "Type": "dissolution",
      "Object": ["lyophilized GelMA: 0.7 g", "PBS: 10 mL", "photoinitiator: 0.5% w/v"],
      "Container": "glass beaker",
      "Description": "Dissolve lyophilized GelMA in PBS containing photoinitiator to prepare the precursor.",
      "Instrument parameters": {
        "magnetic_stirrer": ["60 C"]
      },
      "Product": "GelMA precursor solution",
      "belongto": "Precursor Preparation"
    },
    {
      "Type": "filtration",
      "Object": ["GelMA precursor solution"],
      "Container": "glass beaker",
      "Description": "Filter the GelMA precursor solution for sterilization.",
      "Instrument parameters": {
        "filter": ["0.22 um pore size"]
      },
      "Product": "sterile GelMA precursor solution",
      "belongto": "Precursor Preparation"
    },
    {
      "Type": "mixing",
      "Object": ["sterile GelMA precursor solution", "PRP"],
      "Container": "syringe",
      "Description": "Mix sterile GelMA precursor solution with PRP to form the dispersed phase.",
      "Instrument parameters": {},
      "Product": "GelMA-PRP dispersed phase",
      "belongto": "Precursor Preparation"
    },
    {
      "Type": "mixing",
      "Object": ["paraffin oil", "Span 80"],
      "Container": "syringe",
      "Description": "Prepare the continuous oil phase by mixing paraffin oil with Span 80.",
      "Instrument parameters": {},
      "Product": "continuous oil phase",
      "belongto": "Precursor Preparation"
    },
    {
      "Type": "emulsification",
      "Object": ["GelMA-PRP dispersed phase", "continuous oil phase"],
      "Container": "microfluidic device",
      "Description": "Inject the dispersed and continuous phases into the microfluidic device to form microdroplets.",
      "Instrument parameters": {
        "syringe_pump": ["dispersed: 1.2 mL h-1", "continuous: 12 mL h-1"],
        "microfluidic_device": ["20 C"]
      },
      "Product": "emulsified GelMA-PRP microdroplets",
      "belongto": "Microsphere Fabrication"
    },
    {
      "Type": "uv-irradiation",
      "Object": ["emulsified GelMA-PRP microdroplets"],
      "Container": "collection vial",
      "Description": "UV-cure the collected microdroplets to crosslink GelMA.",
      "Instrument parameters": {
        "UV_device": ["not reported"]
      },
      "Product": "UV-cured GelMA-PRP microspheres",
      "belongto": "Microsphere Fabrication"
    },
    {
      "Type": "washing",
      "Object": ["UV-cured GelMA-PRP microspheres"],
      "Container": "collection vial",
      "Description": "Wash the UV-cured microspheres with water.",
      "Instrument parameters": {},
      "Product": "washed GelMA microspheres",
      "belongto": "Post-processing and Composite Assembly"
    },
    {
      "Type": "mixing",
      "Object": ["washed GelMA microspheres", "PRP-containing hydrogel"],
      "Container": "cryogenic storage vial",
      "Description": "Add washed microspheres to PRP-containing hydrogel to obtain the final composite.",
      "Instrument parameters": {},
      "Product": "PRP@GelMA hydrogel microspheres composite",
      "belongto": "Post-processing and Composite Assembly"
    }
  ],
  "relationship": {
    "serial_dependencies": [
      {
        "from": "PRP Preparation",
        "to": "Precursor Preparation"
      },
      {
        "from": "GelMA Synthesis",
        "to": "Precursor Preparation"
      },
      {
        "from": "Precursor Preparation",
        "to": "Microsphere Fabrication"
      },
      {
        "from": "Microsphere Fabrication",
        "to": "Post-processing and Composite Assembly"
      }
    ],
    "parallel_groups": [
      [
        "PRP Preparation",
        "GelMA Synthesis"
      ]
    ]
  },
  "Missing information": [
    "UV irradiation wavelength and duration not reported",
    "Microsphere washing centrifugation conditions not reported",
    "PRP to GelMA ratio in the dispersed phase not explicitly reported"
  ]
}
